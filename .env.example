# Lighter testnet trading defaults.
LIGHTER_NETWORK=testnet
LIGHTER_BASE_URL=https://testnet.zklighter.elliot.ai
LIGHTER_MARKET_PROFILE=eth_perp
LIGHTER_NONCE_MANAGEMENT=optimistic

# Required for normal signed trading after API key setup.
LIGHTER_ACCOUNT_INDEX=
LIGHTER_API_KEY_INDEX=3
LIGHTER_API_PRIVATE_KEY=

# Required only when creating or rotating a Lighter API key.
# Do not use a funded mainnet wallet key here.
LIGHTER_ETH_PRIVATE_KEY=

# Safety guard. Keep false for testnet work.
LIGHTER_ALLOW_MAINNET=false
