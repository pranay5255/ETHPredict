# Mainnet bot/subaccount credentials.
#
# Mainnet writes require all of:
# - LIGHTER_NETWORK=mainnet
# - LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
# - LIGHTER_ALLOW_MAINNET=true
# - command-level --confirm-mainnet on write helpers
LIGHTER_NETWORK=mainnet
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
LIGHTER_MARKET_PROFILE=eth_perp
LIGHTER_NONCE_MANAGEMENT=api
LIGHTER_ALLOW_MAINNET=false

# Use a dedicated subaccount API key, not the master account key.
LIGHTER_ACCOUNT_INDEX=
LIGHTER_API_KEY_INDEX=
LIGHTER_API_PRIVATE_KEY=

# Keep blank. Do not put an L1 wallet private key in this repo for mainnet.
LIGHTER_ETH_PRIVATE_KEY=
